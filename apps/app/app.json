{
  "expo": {
    "name": "TeamDJ",
    "slug": "teamdj-app",
    "scheme": "teamdj",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.teamdj.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.teamdj.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "갤러리에 접근하여 리포트 이미지를 저장합니다.",
          "savePhotosPermission": "리포트 이미지를 갤러리에 저장합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "질문 첨부를 위해 사진 라이브러리에 접근합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
